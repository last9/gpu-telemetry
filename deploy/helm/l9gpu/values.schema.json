{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/last9/gpu-telemetry/deploy/helm/l9gpu/values.schema.json",
  "title": "l9gpu Helm chart values",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag":        { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "imagePullSecrets": { "type": "array", "items": { "type": "object" } },
    "nameOverride":     { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create":      { "type": "boolean" },
        "annotations": { "type": "object" },
        "name":        { "type": "string" }
      }
    },
    "collectors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nvidia": { "type": "boolean" },
        "amd":    { "type": "boolean" },
        "gaudi":  { "type": "boolean" }
      }
    },
    "otlpSecretName": { "type": "string" },
    "monitoring": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "sink":    { "type": "string", "enum": ["", "stdout", "otel"] },
        "cluster": { "type": "string" }
      }
    },
    "rbac":           { "type": "object" },
    "healthChecks":   { "type": "object" },
    "otelCollector":  { "type": "object" },
    "costMonitor":    { "type": "object" },
    "fleetHealth":    { "type": "object" },
    "nccl":           { "type": "object" },
    "alerts":         { "type": "object" }
  }
}
