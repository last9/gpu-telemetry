[Unit]
Description=Write sacct logs
After=network.target

[Service]
Type=simple
User=cluster_monitor
Environment="PATH=/usr/local/bin:/public/slurm/20.11.3/bin:/usr/sbin:/usr/bin:/sbin:/bin:/opt/slurm/bin"
ExecStart=/usr/bin/l9gpu sacct_backfill new -- /usr/bin/l9gpu sacct_publish
Restart=on-failure
RestartSec=300
Slice=hc_resources.slice
