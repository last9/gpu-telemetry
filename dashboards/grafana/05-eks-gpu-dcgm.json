{
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "text", "name": "Text", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "EKS GPU DCGM Profiling — SM occupancy, compute pipe utilization, DRAM bandwidth and NVLink throughput from dcgm-exporter. Requires dcgm-exporter deployed and scraped via the OTel collector pipeline (k8s_cluster_name label injected by resource processor).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {"h": 3, "w": 24, "x": 0, "y": 0},
      "options": {
        "mode": "markdown",
        "content": "### DCGM Profiling Metrics\nRequires **dcgm-exporter** deployed (`helm install dcgm-exporter dcgm-exporter/dcgm-exporter -n monitoring`) with the profiling metrics CSV enabled, **and** the OTel collector configured to scrape it (see `deploy/helm/l9gpu/examples/eks-otelcol-dcgm.yaml`). The `k8s_cluster_name` label is injected by the OTel `resource` processor. Panel filters use native dcgm-exporter labels: `Hostname` (node), `gpu` (GPU index). **NVLink panels are always empty on T4/A10G nodes** — no NVLink hardware."
      },
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "id": 2,
      "type": "row",
      "title": "SM Utilization & Occupancy",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 3},
      "panels": []
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Graphics / Compute Engine Active (%)",
      "description": "Fraction of time the graphics or compute engine is active (DCGM_FI_PROF_GR_ENGINE_ACTIVE). High values indicate the GPU is being kept busy by workloads.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "DCGM_FI_PROF_GR_ENGINE_ACTIVE{Hostname=~\"$node\", gpu=~\"$gpu_index\"} * 100",
          "legendFormat": "GPU{{gpu}} — {{Hostname}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 4},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": true},
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "SM Active (%)",
      "description": "Fraction of time at least one warp is active on an SM (DCGM_FI_PROF_SM_ACTIVE). Higher is better for throughput. Low SM active + high GR engine active = memory-bound workload.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "DCGM_FI_PROF_SM_ACTIVE{Hostname=~\"$node\", gpu=~\"$gpu_index\"} * 100",
          "legendFormat": "GPU{{gpu}} — {{Hostname}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 4},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": true},
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "SM Occupancy (%)",
      "description": "Fraction of warps resident on an SM relative to the theoretical maximum (DCGM_FI_PROF_SM_OCCUPANCY). Low occupancy limits latency hiding; target >50% for memory-intensive kernels.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "DCGM_FI_PROF_SM_OCCUPANCY{Hostname=~\"$node\", gpu=~\"$gpu_index\"} * 100",
          "legendFormat": "GPU{{gpu}} — {{Hostname}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 4},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": true},
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Compute Pipe Utilization",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 12},
      "panels": []
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Tensor Core Active (%)",
      "description": "Fraction of cycles the tensor core pipe is active (DCGM_FI_PROF_PIPE_TENSOR_ACTIVE). Low values on a transformer/LLM workload indicate the kernel is not issuing matrix ops efficiently. Target >60% for well-optimized inference.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "DCGM_FI_PROF_PIPE_TENSOR_ACTIVE{Hostname=~\"$node\", gpu=~\"$gpu_index\"} * 100",
          "legendFormat": "GPU{{gpu}} — {{Hostname}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": true},
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "FP Pipe Utilization (FP16 / FP32 / FP64) (%)",
      "description": "Fraction of cycles each floating-point pipe is active. FP16 dominates on inference; FP64 should be near-zero on T4 (no FP64 hardware acceleration — ops fall back to FP32).",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "DCGM_FI_PROF_PIPE_FP16_ACTIVE{Hostname=~\"$node\", gpu=~\"$gpu_index\"} * 100",
          "legendFormat": "FP16 GPU{{gpu}} — {{Hostname}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "DCGM_FI_PROF_PIPE_FP32_ACTIVE{Hostname=~\"$node\", gpu=~\"$gpu_index\"} * 100",
          "legendFormat": "FP32 GPU{{gpu}} — {{Hostname}}",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "DCGM_FI_PROF_PIPE_FP64_ACTIVE{Hostname=~\"$node\", gpu=~\"$gpu_index\"} * 100",
          "legendFormat": "FP64 GPU{{gpu}} — {{Hostname}}",
          "refId": "C"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true},
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "row",
      "title": "Memory Bandwidth",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 21},
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "DRAM Bandwidth Active (%)",
      "description": "Fraction of cycles DRAM is actively transferring data (DCGM_FI_PROF_DRAM_ACTIVE). Near 100% = memory-bandwidth-bound. Pair with SM occupancy to diagnose compute vs. memory bottlenecks. T4 peak DRAM bandwidth = 320 GB/s.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "DCGM_FI_PROF_DRAM_ACTIVE{Hostname=~\"$node\", gpu=~\"$gpu_index\"} * 100",
          "legendFormat": "GPU{{gpu}} — {{Hostname}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": true},
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "NVLink Throughput (bytes/s) — empty on T4",
      "description": "NVLink TX + RX bandwidth from DCGM profiling counters. Always empty on T4/A10G nodes (PCIe-only GPUs). Only meaningful on A100/H100 SXM with NVLink fabric.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "DCGM_FI_PROF_NVLINK_TX_BYTES{Hostname=~\"$node\", gpu=~\"$gpu_index\"}",
          "legendFormat": "tx GPU{{gpu}} — {{Hostname}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "DCGM_FI_PROF_NVLINK_RX_BYTES{Hostname=~\"$node\", gpu=~\"$gpu_index\"}",
          "legendFormat": "rx GPU{{gpu}} — {{Hostname}}",
          "refId": "B"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true},
          "unit": "Bps"
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "row",
      "title": "PCIe Bandwidth (Profiling Counters)",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 30},
      "panels": []
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "PCIe TX / RX Throughput (bytes/s)",
      "description": "PCIe bandwidth from DCGM profiling counters (DCGM_FI_PROF_PCIE_TX_BYTES / RX_BYTES). Higher resolution than NVML pcie_throughput; sampled every collection interval.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "DCGM_FI_PROF_PCIE_TX_BYTES{Hostname=~\"$node\", gpu=~\"$gpu_index\"}",
          "legendFormat": "tx GPU{{gpu}} — {{Hostname}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "DCGM_FI_PROF_PCIE_RX_BYTES{Hostname=~\"$node\", gpu=~\"$gpu_index\"}",
          "legendFormat": "rx GPU{{gpu}} — {{Hostname}}",
          "refId": "B"
        }
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 31},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true},
          "unit": "Bps"
        },
        "overrides": []
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["gpu", "eks", "l9gpu", "dcgm", "profiling"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "pluginId": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "skipUrlSync": false
      },
      {
        "name": "cluster",
        "type": "query",
        "label": "Cluster",
        "datasource": {"type": "prometheus", "uid": "$datasource"},
        "definition": "label_values(DCGM_FI_PROF_SM_ACTIVE, job)",
        "query": {
          "query": "label_values(DCGM_FI_PROF_SM_ACTIVE, job)",
          "refId": "StandardVariableQuery"
        },
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 2,
        "sort": 1,
        "skipUrlSync": false
      },
      {
        "name": "node",
        "type": "query",
        "label": "Node",
        "datasource": {"type": "prometheus", "uid": "$datasource"},
        "definition": "label_values(DCGM_FI_PROF_SM_ACTIVE, Hostname)",
        "query": {
          "query": "label_values(DCGM_FI_PROF_SM_ACTIVE, Hostname)",
          "refId": "StandardVariableQuery"
        },
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "options": [],
        "refresh": 2,
        "sort": 1,
        "skipUrlSync": false
      },
      {
        "name": "gpu_index",
        "type": "query",
        "label": "GPU Index",
        "datasource": {"type": "prometheus", "uid": "$datasource"},
        "definition": "label_values(DCGM_FI_PROF_SM_ACTIVE{Hostname=~\"$node\"}, gpu)",
        "query": {
          "query": "label_values(DCGM_FI_PROF_SM_ACTIVE{Hostname=~\"$node\"}, gpu)",
          "refId": "StandardVariableQuery"
        },
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "options": [],
        "refresh": 2,
        "sort": 1,
        "skipUrlSync": false
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "EKS GPU DCGM Profiling",
  "uid": "eksgpudcgm",
  "version": 1
}
