{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "EKS Single GPU Deep Dive — full metric breakdown for one selected GPU for deep debugging",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "GPU Identity",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "GPU Model",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_utilization_ratio{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"}",
          "legendFormat": "{{gpu_model}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "text"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "text", "value": null}]}
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "GPU UUID",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_utilization_ratio{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"}",
          "legendFormat": "{{gpu_uuid}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "text"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "text", "value": null}]}
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Current P-State",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_power_state{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 3},
              {"color": "red", "value": 6}
            ]
          },
          "unit": "short",
          "displayName": "P-State"
        },
        "overrides": []
      }
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Active Pod",
      "description": "K8s pod currently mapped to this GPU (via sequential ordinal assignment).",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_utilization_ratio{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"}",
          "legendFormat": "{{k8s_pod_name}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "text"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "text", "value": null}]},
          "noValue": "—"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "row",
      "title": "Core Metrics",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "panels": []
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "GPU Utilization",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_utilization_ratio{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"} * 100",
          "legendFormat": "utilization",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "options": {
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true},
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Memory Used vs Total (GiB)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_memory_used_bytes{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"} / 1e9",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_memory_total_bytes{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"} / 1e9",
          "legendFormat": "total",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_memory_free_bytes{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"} / 1e9",
          "legendFormat": "free",
          "refId": "C"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 5, "showPoints": "never", "spanNulls": true},
          "unit": "decgbytes"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "total"},
            "properties": [
              {"id": "custom.lineStyle", "value": {"dash": [10, 10], "fill": "dash"}},
              {"id": "custom.fillOpacity", "value": 0}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "free"},
            "properties": [
              {"id": "custom.lineStyle", "value": {"dash": [4, 4], "fill": "dash"}},
              {"id": "custom.fillOpacity", "value": 0},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}
            ]
          }
        ]
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memory Used %",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_memory_used_percent{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"}",
          "legendFormat": "mem used %",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "options": {
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 95}
            ]
          },
          "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true, "thresholdsStyle": {"mode": "line"}},
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Power Draw",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_power_draw_watts{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"}",
          "legendFormat": "power draw",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "options": {
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "orange"},
          "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true},
          "unit": "watt"
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Frequencies & Encode/Decode",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22},
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Clock Frequencies (MHz)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_clock_frequency_MHz{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"}",
          "legendFormat": "{{gpu_clock_type}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 23},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true},
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Encode / Decode Utilization",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_encode_utilization_ratio{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"} * 100",
          "legendFormat": "encode",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_decode_utilization_ratio{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"} * 100",
          "legendFormat": "decode",
          "refId": "B"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 23},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true},
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 13,
      "type": "row",
      "title": "PCIe & Interconnect",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 31},
      "panels": []
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "PCIe Throughput (bytes/s)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_pcie_throughput_bytes_per_second{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"}",
          "legendFormat": "pcie {{gpu_interconnect_direction}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_interconnect_throughput_bytes_per_second{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"}",
          "legendFormat": "nvlink {{gpu_interconnect_direction}}",
          "refId": "B"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true},
          "unit": "Bps"
        },
        "overrides": []
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "PCIe Replay Rate",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "rate(gpu_pcie_replay_count{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"}[5m])",
          "legendFormat": "replay rate",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "options": {
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": true},
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 16,
      "type": "row",
      "title": "Errors & Throttling",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 40},
      "panels": []
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "ECC Errors",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "increase(gpu_ecc_errors{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"}[$__interval])",
          "legendFormat": "{{gpu_ecc_error_type}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 41},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 20, "showPoints": "never", "spanNulls": true, "drawStyle": "bars"},
          "unit": "short",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Row Remap Count",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_row_remap_count{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"}",
          "legendFormat": "row remaps",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 41},
      "options": {
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 512}
            ]
          },
          "custom": {"lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": true},
          "unit": "short",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Throttle Reasons",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_throttle_reason{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"}",
          "legendFormat": "{{gpu_throttle_cause}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 41},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 20, "showPoints": "never", "spanNulls": true},
          "unit": "short",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "id": 21,
      "type": "row",
      "title": "Fan, XID & Volatile ECC",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 49},
      "panels": []
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Fan Speed (%)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_fan_speed_ratio{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"} * 100",
          "legendFormat": "fan speed",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 50},
      "options": {
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          },
          "custom": {"lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true, "thresholdsStyle": {"mode": "line"}},
          "unit": "percent",
          "min": 0,
          "max": 100,
          "noValue": "N/A"
        },
        "overrides": []
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "XID Errors",
      "description": "XID errors reported by the NVIDIA driver. Any non-zero value warrants investigation.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_xid_errors{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\"}",
          "legendFormat": "xid errors",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 50},
      "options": {
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "custom": {"lineWidth": 1, "fillOpacity": 20, "showPoints": "never", "spanNulls": true, "drawStyle": "bars"},
          "unit": "short",
          "min": 0,
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Volatile ECC Errors (current session)",
      "description": "ECC errors since last driver reset. Separate from cumulative retired-page counts.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_ecc_errors{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\", gpu_ecc_count_type=\"volatile\", gpu_ecc_error_type=\"correctable\"}",
          "legendFormat": "correctable",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_ecc_errors{k8s_cluster_name=\"$cluster\", host_name=\"$node\", gpu_index=\"$gpu_index\", gpu_ecc_count_type=\"volatile\", gpu_ecc_error_type=\"uncorrectable\"}",
          "legendFormat": "uncorrectable",
          "refId": "B"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 50},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
