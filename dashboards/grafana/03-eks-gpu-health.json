{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "EKS GPU Health & Reliability — SRE on-call view for anomaly detection, errors, throttling, and temperature",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Error Counters (1h)",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "ECC Correctable (1h)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "sum(increase(gpu_ecc_errors{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_ecc_error_type=\"correctable\"}[1h]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 10}
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "ECC Uncorrectable (1h)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "sum(increase(gpu_ecc_errors{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_ecc_error_type=\"uncorrectable\"}[1h]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "PCIe Replays (1h)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "sum(increase(gpu_pcie_replay_count{k8s_cluster_name=\"$cluster\", host_name=~\"$node\"}[1h]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 100}
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Row Remaps (memory cell health)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "sum(gpu_row_remap_count{k8s_cluster_name=\"$cluster\", host_name=~\"$node\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 512}
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 19,
      "type": "stat",
      "title": "XID Errors (1h)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "sum(increase(gpu_xid_errors{k8s_cluster_name=\"$cluster\", host_name=~\"$node\"}[1h]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Max Fan Speed (%)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "max(gpu_fan_speed_ratio{k8s_cluster_name=\"$cluster\", host_name=~\"$node\"}) * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "noValue": "N/A"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Throttle Reasons",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "panels": []
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Throttle: Power (Software)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_throttle_reason{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_index=~\"$gpu_index\", gpu_throttle_cause=\"power_software\"}",
          "legendFormat": "{{host_name}} GPU{{gpu_index}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 6},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "orange"},
          "custom": {"lineWidth": 1, "fillOpacity": 20, "showPoints": "never", "spanNulls": true},
          "unit": "short",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Throttle: Temp (Hardware)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_throttle_reason{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_index=~\"$gpu_index\", gpu_throttle_cause=\"temp_hardware\"}",
          "legendFormat": "{{host_name}} GPU{{gpu_index}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 6},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "custom": {"lineWidth": 1, "fillOpacity": 20, "showPoints": "never", "spanNulls": true},
          "unit": "short",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Throttle: Temp (Software)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_throttle_reason{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_index=~\"$gpu_index\", gpu_throttle_cause=\"temp_software\"}",
          "legendFormat": "{{host_name}} GPU{{gpu_index}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 6},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "yellow"},
          "custom": {"lineWidth": 1, "fillOpacity": 20, "showPoints": "never", "spanNulls": true},
          "unit": "short",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Throttle: Sync Boost",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_throttle_reason{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_index=~\"$gpu_index\", gpu_throttle_cause=\"syncboost\"}",
          "legendFormat": "{{host_name}} GPU{{gpu_index}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 6},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 20, "showPoints": "never", "spanNulls": true},
          "unit": "short",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "type": "row",
      "title": "Temperature & Clocks",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "panels": []
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "GPU Temperature",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_temperature_celsius{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_index=~\"$gpu_index\"}",
          "legendFormat": "{{host_name}} GPU{{gpu_index}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 15},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 90}
            ]
          },
          "custom": {"lineWidth": 2, "fillOpacity": 5, "showPoints": "never", "spanNulls": true, "thresholdsStyle": {"mode": "line+area"}},
          "unit": "celsius"
        },
        "overrides": []
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Clock: Graphics Frequency (MHz)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_clock_frequency_MHz{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_index=~\"$gpu_index\", gpu_clock_type=\"graphics\"}",
          "legendFormat": "{{host_name}} GPU{{gpu_index}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 15},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true},
          "unit": "short",
          "displayName": "${__field.displayName} MHz"
        },
        "overrides": []
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Clock: Memory Frequency (MHz)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_clock_frequency_MHz{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_index=~\"$gpu_index\", gpu_clock_type=\"memory\"}",
          "legendFormat": "{{host_name}} GPU{{gpu_index}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 15},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true},
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 15,
      "type": "row",
      "title": "P-State & Energy",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "panels": []
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "P-State",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_power_state{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_index=~\"$gpu_index\"}",
          "legendFormat": "GPU{{gpu_index}} — {{host_name}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true},
          "unit": "short",
          "min": 0,
          "max": 8
        },
        "overrides": []
      }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Energy Rate (W, derived from mJ counter)",
      "description": "rate(gpu_energy_consumption_mJ[1m]) gives mJ/s; dividing by 1000 converts to Watts.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "rate(gpu_energy_consumption_mJ{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_index=~\"$gpu_index\"}[1m]) / 1000",
          "legendFormat": "GPU{{gpu_index}} — {{host_name}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true},
          "unit": "watt"
        },
        "overrides": []
      }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "PCIe Replay Rate",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "rate(gpu_pcie_replay_count{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_index=~\"$gpu_index\"}[5m])",
          "legendFormat": "GPU{{gpu_index}} — {{host_name}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "custom": {"lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": true},
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 21,
      "type": "row",
      "title": "Fan Speed & Volatile ECC",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32},
      "panels": []
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Fan Speed (%)",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_fan_speed_ratio{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_index=~\"$gpu_index\"} * 100",
          "legendFormat": "GPU{{gpu_index}} — {{host_name}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 33},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true},
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Volatile ECC Errors (current session)",
      "description": "ECC errors since last driver reset (volatile counters). Separate from cumulative retired-page counts.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_ecc_errors{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_index=~\"$gpu_index\", gpu_ecc_count_type=\"volatile\", gpu_ecc_error_type=\"correctable\"}",
          "legendFormat": "correctable GPU{{gpu_index}} — {{host_name}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "gpu_ecc_errors{k8s_cluster_name=\"$cluster\", host_name=~\"$node\", gpu_index=~\"$gpu_index\", gpu_ecc_count_type=\"volatile\", gpu_ecc_error_type=\"uncorrectable\"}",
          "legendFormat": "uncorrectable GPU{{gpu_index}} — {{host_name}}",
          "refId": "B"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 33},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 20, "showPoints": "never", "spanNulls": true, "drawStyle": "bars"},
          "unit": "short",
          "min": 0,
          "noValue": "0"
        },
        "overrides": []
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["gpu", "eks", "l9gpu", "health", "reliability", "sre"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "pluginId": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "skipUrlSync": false
      },
      {
        "name": "cluster",
        "type": "query",
        "label": "Cluster",
        "datasource": {"type": "prometheus", "uid": "$datasource"},
