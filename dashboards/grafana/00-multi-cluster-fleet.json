{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""},
    {"type": "panel", "id": "bargauge", "name": "Bar gauge", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "Multi-Cluster GPU Fleet Overview — single pane of glass across all GPU clusters",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Fleet Overview (single cluster)",
      "url": "/d/eksgpuovr/eks-gpu-fleet-overview?var-cluster=${cluster}",
      "type": "link",
      "icon": "external link",
      "tooltip": "Drill into a single cluster's GPU fleet",
      "targetBlank": false
    },
    {
      "title": "Inference Performance",
      "url": "/d/gpuinference/llm-inference-performance?var-cluster=${cluster}",
      "type": "link",
      "icon": "external link",
      "tooltip": "LLM inference latency, throughput, and cache metrics",
      "targetBlank": false
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Fleet Summary",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total GPUs",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "count(gpu_utilization_ratio{k8s_cluster_name=~\"$cluster\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "blue"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Utilization",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "avg(gpu_utilization_ratio{k8s_cluster_name=~\"$cluster\"}) * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 30},
              {"color": "green", "value": 50}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Max Utilization",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "max(gpu_utilization_ratio{k8s_cluster_name=~\"$cluster\"}) * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 95}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Idle GPUs (<10%)",
      "description": "GPUs with utilization below 10%. High count = wasted spend.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "count(gpu_utilization_ratio{k8s_cluster_name=~\"$cluster\"} < 0.10) or vector(0)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 2},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Max Temperature",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "max(gpu_temperature_celsius{k8s_cluster_name=~\"$cluster\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 90}
            ]
          },
          "unit": "celsius"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Inference TTFT P95",
      "description": "Worst time-to-first-token across all inference instances. N/A if no inference engine is deployed.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "max(vllm_ttft_seconds{k8s_cluster_name=~\"$cluster\", quantile=\"p95\"}) * 1000",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 200},
              {"color": "red", "value": 500}
            ]
          },
          "unit": "ms",
          "noValue": "N/A"
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "row",
      "title": "Per-Cluster Breakdown",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "panels": []
    },
    {
      "id": 9,
      "type": "table",
      "title": "Cluster Overview",
      "description": "One row per cluster showing key fleet metrics.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "count by (k8s_cluster_name) (gpu_utilization_ratio{k8s_cluster_name=~\"$cluster\"})",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "avg by (k8s_cluster_name) (gpu_utilization_ratio{k8s_cluster_name=~\"$cluster\"}) * 100",
          "legendFormat": "",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "max by (k8s_cluster_name) (gpu_temperature_celsius{k8s_cluster_name=~\"$cluster\"})",
          "legendFormat": "",
          "refId": "C",
          "format": "table",
          "instant": true
        },
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "sum by (k8s_cluster_name) (gpu_power_draw_watts{k8s_cluster_name=~\"$cluster\"})",
          "legendFormat": "",
          "refId": "D",
          "format": "table",
          "instant": true
        },
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "sum by (k8s_cluster_name) (increase(gpu_ecc_errors{k8s_cluster_name=~\"$cluster\"}[1h]))",
          "legendFormat": "",
          "refId": "E",
          "format": "table",
          "instant": true
        }
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 6},
      "options": {
        "showHeader": true,
        "footer": {"show": true, "reducer": ["sum"], "countRows": false}
      },
      "transformations": [
        {"id": "merge", "options": {}},
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true},
            "renameByName": {
              "k8s_cluster_name": "Cluster",
              "Value #A": "GPU Count",
              "Value #B": "Avg Util %",
              "Value #C": "Max Temp °C",
              "Value #D": "Total Power W",
              "Value #E": "ECC Errors (1h)"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "cellOptions": {"type": "auto"}},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Avg Util %"},
            "properties": [
              {"id": "custom.cellOptions", "value": {"type": "gauge", "mode": "gradient"}},
              {"id": "min", "value": 0},
              {"id": "max", "value": 100},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 30}, {"color": "green", "value": 50}]}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Max Temp °C"},
            "properties": [
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 80}, {"color": "red", "value": 90}]}},
              {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "ECC Errors (1h)"},
            "properties": [
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}},
              {"id": "custom.cellOptions", "value": {"type": "color-background"}}
            ]
          }
        ]
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "GPU Utilization Across Clusters",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Avg GPU Utilization by Cluster",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "avg by (k8s_cluster_name) (gpu_utilization_ratio{k8s_cluster_name=~\"$cluster\"}) * 100",
          "legendFormat": "{{k8s_cluster_name}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true},
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Avg GPU Memory Used % by Cluster",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "avg by (k8s_cluster_name) (gpu_memory_used_percent{k8s_cluster_name=~\"$cluster\"})",
          "legendFormat": "{{k8s_cluster_name}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true},
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 13,
      "type": "row",
      "title": "Top GPUs — Hottest and Most Utilized",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "panels": []
    },
    {
      "id": 14,
      "type": "bargauge",
      "title": "Top 10 Hottest GPUs",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "topk(10, gpu_temperature_celsius{k8s_cluster_name=~\"$cluster\"})",
          "legendFormat": "{{k8s_cluster_name}} {{host_name}} GPU{{gpu_index}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 75},
              {"color": "red", "value": 85}
            ]
          },
          "unit": "celsius"
        },
        "overrides": []
      }
    },
    {
      "id": 15,
      "type": "bargauge",
      "title": "Top 10 Most-Utilized GPUs",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "topk(10, gpu_utilization_ratio{k8s_cluster_name=~\"$cluster\"}) * 100",
          "legendFormat": "{{k8s_cluster_name}} {{host_name}} GPU{{gpu_index}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 16,
      "type": "row",
      "title": "Inference Latency by Cluster",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32},
      "panels": []
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "TTFT P95 by Cluster (ms)",
      "description": "Time-to-first-token P95 per cluster. Only visible if a vLLM/inference monitor is deployed.",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "max by (k8s_cluster_name) (vllm_ttft_seconds{k8s_cluster_name=~\"$cluster\", quantile=\"p95\"}) * 1000",
          "legendFormat": "{{k8s_cluster_name}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 33},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "never",
            "spanNulls": true,
            "thresholdsStyle": {"mode": "line"}
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "transparent", "value": null},
              {"color": "red", "value": 500}
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      }
    },
    {
      "id": 18,
