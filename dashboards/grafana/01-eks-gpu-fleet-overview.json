{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "bargauge", "name": "Bar gauge", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "EKS GPU Fleet Overview — operations-level single-pane-of-glass for l9gpu cluster health",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Multi-Cluster Fleet",
      "url": "/d/multiclusterfleet/multi-cluster-gpu-fleet-overview",
      "type": "link",
      "icon": "external link",
      "tooltip": "Cross-cluster fleet overview",
      "targetBlank": false
    },
    {
      "title": "Workload Attribution",
      "url": "/d/eksgpuwork/eks-gpu-workload?var-cluster=${cluster}",
      "type": "link",
      "icon": "external link",
      "tooltip": "Per-pod GPU consumption breakdown",
      "targetBlank": false
    },
    {
      "title": "Health & Reliability",
      "url": "/d/eksgpuhealth/eks-gpu-health?var-cluster=${cluster}",
      "type": "link",
      "icon": "external link",
      "tooltip": "ECC errors, throttling, XID faults",
      "targetBlank": false
    },
    {
      "title": "Single GPU Deep Dive",
      "url": "/d/eksgpusingle/eks-single-gpu-deep-dive?var-cluster=${cluster}&var-node=${node}&var-gpu_index=0",
      "type": "link",
      "icon": "external link",
      "tooltip": "Full metric breakdown for one GPU",
      "targetBlank": false
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Fleet Stats",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "GPU Count",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "count(gpu_utilization_ratio{k8s_cluster_name=\"$cluster\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "blue"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg GPU Utilization",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "avg(gpu_utilization_ratio{k8s_cluster_name=\"$cluster\"}) * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Power Draw",
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "sum(gpu_power_draw_watts{k8s_cluster_name=\"$cluster\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "orange"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "orange", "value": null}]},
          "unit": "watt"
        },
        "overrides": []
      }
    },
